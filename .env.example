# =============================================================================
# TPRMAI Environment Configuration
# =============================================================================
# Copy to .env for local development: cp .env.example .env

# ---------- Database ----------
# Docker Compose (local): postgresql://tprm_user:tprm_pass@localhost:5438/tprm_db
# Docker internal:        postgresql://tprm_user:tprm_pass@db:5432/tprm_db
DATABASE_URL="postgresql://tprm_user:tprm_pass@localhost:5438/tprm_db"

# ---------- Authentication (OIDC + JWT) ----------
# OIDC Provider (mock-oidc for local dev, Azure AD/Okta/etc for production)
OIDC_ISSUER_URL=http://localhost:10091
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# JWT signing secret -- generate with: openssl rand -hex 32
JWT_SECRET=

# Set to "true" in production to enforce real secrets (fatal error on defaults)
ENFORCE_SECRETS=false

# App URL (used for OIDC redirect_uri)
NEXTAUTH_URL="http://localhost:3020"

# Production OIDC (uncomment and configure for your provider)
# Azure AD / Entra ID:
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant_id}/v2.0
# Okta:
# OIDC_ISSUER_URL=https://{org}.okta.com/oauth2/default

# ---------- AI Provider ----------
# Supported: anthropic_foundry, claude, openai, ollama
AI_PROVIDER="anthropic_foundry"

# Azure AI Foundry with Claude (API key or Entra ID auth)
# If API key is set, uses it directly. If empty, falls back to DefaultAzureCredential (az login).
AZURE_AI_FOUNDRY_ENDPOINT="https://your-resource.services.ai.azure.com/anthropic"
AZURE_AI_FOUNDRY_API_KEY=

# Model deployment names (must match Azure AI Foundry deployment names)
AI_MODEL_COMPLEX=                           # CARA, SARA (deep analysis)
AI_MODEL_STANDARD=                          # VERA, RITA, MARS (standard reasoning)
AI_MODEL_SIMPLE=                            # DORA (document retrieval)

# Fallback model deployment (optional)
AZURE_AI_FOUNDRY_FALLBACK_MODEL=

# Direct Claude API (alternative to Azure AI Foundry)
# ANTHROPIC_API_KEY=

# OpenAI API (alternative)
# OPENAI_API_KEY=

# Ollama (local, alternative)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ---------- General API Rate Limiting ----------
API_RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ---------- AI Safety Controls ----------
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=20
AI_RATE_LIMIT_TOKENS_PER_MINUTE=50000
AI_MAX_PROMPT_CHARS=100000
AI_MAX_DOCUMENT_CHARS=500000
AI_PII_MASKING_ENABLED=true

# ---------- External Security APIs (optional) ----------
SECURITY_SCORECARD_API_KEY=""
BITSIGHT_API_KEY=""
DNB_API_KEY=""

# ---------- File Upload & Document Storage ----------
# Persistent document storage (Docker volume: tprmai-documents)
DOCUMENTS_PATH="/app/data/documents"
# Temporary upload cache (cleaned periodically)
UPLOAD_CACHE_PATH="/app/data/uploads"
MAX_FILE_SIZE="52428800"
